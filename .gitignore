covers/*
!covers/.gitkeep

# 不进 repo：实际数据（小说原文 / 输出 mp3）— 用户 NOVEL_ROOT 默认在 ~/Documents/novel，与本 repo 分离
txt/
input/
output/
output_easyvoice/

# IDE / 编辑器
.idea/
.vscode/
*.swp
